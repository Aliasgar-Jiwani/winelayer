# ─── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.pyright/
pyrightconfig.json

# ─── Flutter / Dart ───────────────────────────────────────────
winelayer/app/.dart_tool/
winelayer/app/.flutter-plugins
winelayer/app/.flutter-plugins-dependencies
winelayer/app/build/
winelayer/app/*.g.dart
winelayer/app/pubspec.lock

# ─── SQLite Database (user data — never commit this) ──────────
*.db
*.sqlite
*.db-journal

# ─── Logs ─────────────────────────────────────────────────────
*.log
winelayer/logs/

# ─── OS Clutter ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor / IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.editorconfig

# ─── Wine Prefixes (huge, user-specific) ──────────────────────
winelayer/prefixes/

# ─── Secrets (never commit) ───────────────────────────────────
.env
*.key
*.pem
secrets.json
